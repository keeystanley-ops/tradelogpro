{
  "version": 2,
  "cleanUrls": true,
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/|assets/|images/|favicon\\.svg|landing_bg\\.png|opengraph\\.jpg).*)",
      "destination": "/index.html"
    }
  ]
}
